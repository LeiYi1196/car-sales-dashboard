{% if summary.order_count == 0 %}
  <div class="empty-state">
    <h2>No data in the selected range</h2>
    <p>Widen the date range or reset the filters.</p>
  </div>
{% else %}

{% set kpi = {
  'total_sales': summary.total_sales,
  'total_quantity': summary.total_quantity,
  'order_count': summary.order_count,
  'count_label': 'Countries',
  'count_value': summary.country_count,
  'pop_pct': summary.pop_pct,
  'yoy_pct': summary.yoy_pct,
  'granularity': summary.granularity,
} %}
{% include "partials/kpi_cards.html.j2" %}

<div class="chart-card">
  <div class="card-header">
    <h2>{{ pop_label(summary.granularity) }} Trend</h2>
    <div class="card-sub">Sales and unit volume across all selected countries</div>
  </div>
  {{ trend_chart | safe }}
</div>

<div class="country-grid">
  {% for c in cards %}
  <a class="country-card" href="/country/{{ c.slug }}{% if query_string %}?{{ query_string }}{% endif %}">
    <div class="country-name">{{ c.display_name }}</div>
    <div class="country-sub">{{ c.country }} · {{ c.currency }}</div>
    <div class="stats">
      <div>
        <div class="stat-label">Sales</div>
        <div class="stat-value">{{ fmt_money(c.total_sales) }}</div>
      </div>
      <div>
        <div class="stat-label">Units</div>
        <div class="stat-value">{{ fmt_int(c.total_quantity) }}</div>
      </div>
      <div>
        <div class="stat-label">Orders</div>
        <div class="stat-value">{{ fmt_int(c.order_count) }}</div>
      </div>
      <div>
        <div class="stat-label">Models</div>
        <div class="stat-value">{{ c.model_count }}</div>
      </div>
    </div>
    <div class="spark">{{ c.spark_html | safe }}</div>
    <div class="arrow">View details →</div>
  </a>
  {% endfor %}
</div>

<div class="chart-card">
  <h2>Sales by Country</h2>
  {{ comparison_chart | safe }}
</div>

{% with trend_rows=summary.trend.to_dict(orient='records'), granularity=summary.granularity %}
  {% include "partials/trend_table.html.j2" %}
{% endwith %}

{% endif %}
